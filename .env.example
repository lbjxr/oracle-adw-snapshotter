# Oracle Autonomous Data Warehouse (ADW) connection
#
# Common patterns:
# 1) Thin mode + wallet/config_dir (recommended default for ADW)
# 2) Thick mode + Oracle Instant Client + optional wallet/config_dir
#
# DSN examples:
#   ORACLE_DSN=adb.eu-frankfurt-1.oraclecloud.com/your_tp_service
#   ORACLE_DSN=yourdb_high
#   ORACLE_DSN=(description=...)

ORACLE_USER=ADMIN
ORACLE_PASSWORD=replace_with_real_password
ORACLE_DSN=myadw_high

# Connection mode: thin (default) or thick
ORACLE_CONNECTION_MODE=thin

# Wallet / network admin files
# Put your unzipped wallet directory inside this project, for example:
#   ./secrets/oracle-wallet/Wallet_myadw
# Usually tnsnames.ora / sqlnet.ora live inside that directory.
ORACLE_WALLET_DIR=./secrets/oracle-wallet/Wallet_myadw

# Needed only when the wallet zip is password-protected for mTLS usage.
ORACLE_WALLET_PASSWORD=

# Optional override for network config directory.
# If empty, the app falls back to ORACLE_WALLET_DIR when resolving TNS aliases.
# Set this if you want wallet files and network config files to live in different places.
ORACLE_CONFIG_DIR=

# Thick mode only: Oracle Instant Client lib directory.
# Examples:
#   Linux:  /opt/oracle/instantclient_23_5
#   macOS:  /opt/oracle/instantclient_23_3
#   Windows: C:\oracle\instantclient_23_5
ORACLE_LIB_DIR=

# Runtime settings
SNAPSHOT_APP_NAME=oracle-adw-snapshotter
SNAPSHOT_CONFIG_PATH=config/tasks.yaml
SNAPSHOT_DEFAULT_OWNER=
SNAPSHOT_FETCH_SIZE=1000
